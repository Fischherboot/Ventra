<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFA6A6A6">

    <!-- Turn Flash Overlay -->
    <TextView
        android:id="@+id/txtFlash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#FFFFFFFF"
        android:textSize="52sp"
        android:textStyle="bold"
        android:background="#CC000000"
        android:visibility="gone" />

    <!-- Setup Screen -->
    <LinearLayout
        android:id="@+id/setupScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mensch ärgere\ndich nicht"
            android:textColor="#FF1A1A1A"
            android:textSize="44sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button android:id="@+id/btn2Players" android:layout_width="400dp" android:layout_height="88dp"
            android:layout_marginBottom="16dp" android:background="@drawable/btn_difficulty"
            android:text="2 Spieler (1 Roboter)" android:textColor="#FFFFFFFF" android:textSize="28sp" android:textStyle="bold" />
        <Button android:id="@+id/btn3Players" android:layout_width="400dp" android:layout_height="88dp"
            android:layout_marginBottom="16dp" android:background="@drawable/btn_difficulty"
            android:text="3 Spieler (2 Roboter)" android:textColor="#FFFFFFFF" android:textSize="28sp" android:textStyle="bold" />
        <Button android:id="@+id/btn4Players" android:layout_width="400dp" android:layout_height="88dp"
            android:layout_marginBottom="16dp" android:background="@drawable/btn_difficulty"
            android:text="4 Spieler (3 Roboter)" android:textColor="#FFFFFFFF" android:textSize="28sp" android:textStyle="bold" />
        <Button android:id="@+id/btn2Local" android:layout_width="400dp" android:layout_height="88dp"
            android:layout_marginBottom="32dp" android:background="@drawable/btn_primary"
            android:text="👥 Zu zweit lokal" android:textColor="#FFFFFFFF" android:textSize="28sp" android:textStyle="bold" />
        <Button android:id="@+id/btnBackSetup" android:layout_width="400dp" android:layout_height="80dp"
            android:background="@drawable/btn_back" android:text="@string/btn_back"
            android:textColor="#FFFFFFFF" android:textSize="28sp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Game Screen -->
    <LinearLayout
        android:id="@+id/gameScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone">

        <!-- Board -->
        <FrameLayout
            android:id="@+id/boardContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:padding="4dp" />

        <!-- Side panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:gravity="center_horizontal">

            <TextView android:id="@+id/txtStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textColor="#FF1A1A1A" android:textSize="24sp"
                android:textStyle="bold" android:paddingBottom="8dp" />

            <TextView android:id="@+id/txtDice"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="56sp" android:paddingBottom="8dp" />

            <Button android:id="@+id/btnRoll"
                android:layout_width="match_parent" android:layout_height="80dp"
                android:layout_marginBottom="10dp" android:background="@drawable/btn_difficulty"
                android:text="🎲  Würfeln" android:textColor="#FFFFFFFF"
                android:textSize="26sp" android:textStyle="bold" />

            <!-- Piece selection buttons -->
            <TextView android:id="@+id/txtPickPiece"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:text="Figur wählen:"
                android:textColor="#FF555555" android:textSize="20sp"
                android:paddingBottom="4dp" android:visibility="gone" />

            <LinearLayout
                android:id="@+id/pieceButtonsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <Button android:id="@+id/btnPiece1" android:layout_width="0dp" android:layout_height="64dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:background="@drawable/btn_primary" android:text="1"
                    android:textColor="#FFFFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/btnPiece2" android:layout_width="0dp" android:layout_height="64dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:background="@drawable/btn_primary" android:text="2"
                    android:textColor="#FFFFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/btnPiece3" android:layout_width="0dp" android:layout_height="64dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:background="@drawable/btn_primary" android:text="3"
                    android:textColor="#FFFFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/btnPiece4" android:layout_width="0dp" android:layout_height="64dp"
                    android:layout_weight="1" android:layout_margin="3dp"
                    android:background="@drawable/btn_primary" android:text="4"
                    android:textColor="#FFFFFFFF" android:textSize="26sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />

            <Button android:id="@+id/btnNewGame" android:layout_width="match_parent" android:layout_height="56dp"
                android:layout_marginBottom="6dp" android:background="@drawable/btn_new_game"
                android:text="@string/btn_new_game" android:textColor="#FFFFFFFF" android:textSize="20sp" android:textStyle="bold" />
            <Button android:id="@+id/btnBack" android:layout_width="match_parent" android:layout_height="56dp"
                android:layout_marginBottom="6dp" android:background="@drawable/btn_back"
                android:text="@string/btn_back" android:textColor="#FFFFFFFF" android:textSize="20sp" android:textStyle="bold" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="end" android:text="© Moritzsoft" android:textColor="#88555555" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
